import { useEffect, useRef, type ReactNode, type RefObject } from 'react';
import '../../../runtime/src/renderer/styles/requirements-doc.css';
import {
  filterDocSections,
  parseRequirementsDoc,
  subsectionIcon,
  type CheckItem,
  type DocBlock,
  type DocSection,
  type ListItem,
  type ParsedRequirementsDoc,
} from '@prototype/runtime/parseRequirementsDoc';
import { findPrdSectionElement, scrollPrdSectionIntoView, sectionDomId } from '@prototype/review';
import { FaIcon } from '@prototype/ui/Icon';
import type { ProjectItem } from '@prototype/renderer/types';
import type { SectionEditorState } from '../lib/useSectionEditor';

interface RequirementsDocViewProps {
  text: string;
  /** 弹窗模式时隐藏顶部大标题 */
  compact?: boolean;
  /** 侧栏对照：缩小卡片间距与字号 */
  dense?: boolean;
  /** 按原型页面过滤章节（如 list / form）；null 表示不过滤 */
  pageScope?: string | null;
  /** 对照定位：高亮并滚动到该章节（anchorId 或 title） */
  highlightKey?: string | null;
  /** 对照定位：高亮表格中第一列匹配的行 */
  highlightTableRow?: string | null;
  /** 每次定位递增，重复点击同一章节时重新滚动 */
  locateToken?: number;
  /** 实际滚动的容器（分屏 PRD 侧栏外层 overflow-auto） */
  scrollContainerRef?: RefObject<HTMLElement | null> | null;
  /** 分屏对照：点击 PRD 章节/表格行 */
  interactive?: boolean;
  onPrdPick?: (target: { anchorId: string; rowLabel?: string | null; sectionTitle?: string }) => void;
  /** 是否启用 per-section 编辑 */
  editable?: boolean;
  /** 来自 useSectionEditor hook 的状态 */
  sectionEditor?: SectionEditorState;
  /** 用于保存 */
  project?: ProjectItem;
  /** 原始 PRD 全文 */
  originalPrdText?: string;
}

export function RequirementsDocView({
  text,
  compact = false,
  dense = false,
  pageScope = null,
  highlightKey = null,
  highlightTableRow = null,
  locateToken = 0,
  scrollContainerRef = null,
  interactive = false,
  onPrdPick,
  editable = false,
  sectionEditor,
}: RequirementsDocViewProps) {
  const doc = parseRequirementsDoc(text);
  const scoped = filterDocSections(doc.sections, pageScope);
  const sections =
    highlightKey && pageScope
      ? (() => {
          const target = doc.sections.find(
            (s) => s.anchorId === highlightKey || s.title === highlightKey,
          );
          if (target && !scoped.some((s) => s.anchorId === target.anchorId && s.title === target.title)) {
            const merged = [...scoped, target];
            merged.sort((a, b) => doc.sections.indexOf(a) - doc.sections.indexOf(b));
            return merged;
          }
          return scoped;
        })()
      : scoped;
  const contentRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (!highlightKey) return;
    const sectionEl = findPrdSectionElement(contentRef.current, highlightKey);
    if (!sectionEl) return;

    const scrollContainer = scrollContainerRef?.current;
    if (scrollContainer) {
      scrollPrdSectionIntoView(scrollContainer, sectionEl);
    } else {
      sectionEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [highlightKey, highlightTableRow, locateToken, pageScope, scrollContainerRef]);

  const isHighlighted = (section: DocSection) =>
    highlightKey != null &&
    (highlightKey === section.anchorId || highlightKey === section.title);

  return (
    <div ref={contentRef} className={`requirements-doc logic-doc ${dense ? 'logic-doc--dense' : ''}`}>
      {!compact && (
        <div className="mb-6 flex items-center gap-3 pb-4 border-b border-border-light">
          <FaIcon className="fas fa-book text-primary text-lg" />
          <h1 className="font-semibold text-primary text-lg">{doc.title}</h1>
        </div>
      )}
      {sections.length === 0 && pageScope ? (
        <p className={`text-text-muted ${dense ? 'text-xs' : 'text-sm'}`}>
          当前页面（{pageScope}）暂无 PRD 交互规格章节
        </p>
      ) : null}
      {sections.map((section) => {
        const sectionKey = section.anchorId ?? section.title;
        const isEditing =
          !!sectionEditor && editable && sectionEditor.editingKey === sectionKey;
        return (
          <LogicDocCard
            key={sectionKey}
            id={sectionDomId(section)}
            title={section.title}
            icon={section.icon}
            dense={dense}
            highlighted={isHighlighted(section) && !isEditing}
            interactive={interactive && !!section.anchorId && !isEditing}
            onHeaderClick={
              section.anchorId && onPrdPick && !isEditing
                ? () =>
                    onPrdPick({
                      anchorId: section.anchorId!,
                      rowLabel: null,
                      sectionTitle: section.title,
                    })
                : undefined
            }
            actions={
              editable && sectionEditor && !isEditing ? (
                <button
                  type="button"
                  className="ml-auto inline-flex items-center justify-center w-7 h-7 rounded text-text-muted hover:text-primary hover:bg-primary/8 transition-colors"
                  title="编辑该章节"
                  aria-label="编辑该章节"
                  onClick={() => sectionEditor.startEdit(section)}
                >
                  <FaIcon className="fas fa-pen text-[11px]" />
                </button>
              ) : null
            }
          >
            <SectionBody
              section={section}
              dense={dense}
              highlightTableRow={isHighlighted(section) ? highlightTableRow : null}
              interactive={interactive}
              sectionAnchorId={section.anchorId}
              onPrdPick={onPrdPick}
            />
          </LogicDocCard>
        );
      })}
    </div>
  );
}

function SectionBody({
  section,
  dense = false,
  highlightTableRow = null,
  interactive = false,
  sectionAnchorId,
  onPrdPick,
}: {
  section: DocSection;
  dense?: boolean;
  highlightTableRow?: string | null;
  interactive?: boolean;
  sectionAnchorId?: string;
  onPrdPick?: RequirementsDocViewProps['onPrdPick'];
}) {
  if (!section.blocks.length) {
    return <p className={`text-text-muted ${dense ? 'text-xs' : 'text-sm'}`}>暂无内容</p>;
  }
  return (
    <div className={dense ? 'space-y-2' : 'space-y-4'}>
      {section.blocks.map((block, i) => (
        <BlockRenderer
          key={`${section.title}-${i}`}
          block={block}
          sectionTitle={section.title}
          dense={dense}
          highlightTableRow={highlightTableRow}
          interactive={interactive}
          sectionAnchorId={sectionAnchorId}
          onPrdPick={onPrdPick}
        />
      ))}
    </div>
  );
}

function BlockRenderer({
  block,
  sectionTitle,
  dense = false,
  highlightTableRow = null,
  interactive = false,
  sectionAnchorId,
  onPrdPick,
}: {
  block: DocBlock;
  sectionTitle: string;
  dense?: boolean;
  highlightTableRow?: string | null;
  interactive?: boolean;
  sectionAnchorId?: string;
  onPrdPick?: RequirementsDocViewProps['onPrdPick'];
}) {
  switch (block.type) {
    case 'paragraph':
      return <p className="text-sm text-text-secondary leading-relaxed">{block.text}</p>;
    case 'list':
      return <ListTable items={block.items} columns={listColumnsFor(sectionTitle)} />;
    case 'checklist':
      return <ChecklistTable items={block.items} dense={dense} />;
    case 'subsection':
      return (
        <div>
          <h5 className="font-semibold text-dark mb-2 flex items-center text-sm">
            <FaIcon className={`${subsectionIcon(block.title)} mr-2 text-primary text-xs`} />
            {block.title}
          </h5>
          <div className={dense ? 'space-y-2' : 'space-y-3'}>
            {block.blocks.map((inner, j) => (
              <BlockRenderer
                key={`${block.title}-${j}`}
                block={inner}
                sectionTitle={sectionTitle}
                dense={dense}
                highlightTableRow={highlightTableRow}
                interactive={interactive}
                sectionAnchorId={sectionAnchorId}
                onPrdPick={onPrdPick}
              />
            ))}
          </div>
        </div>
      );
    case 'changelog-entry':
      return (
        <div className="border border-border rounded-lg p-4 bg-stone-50/50">
          <div className="font-semibold text-primary text-sm">
            {block.entry.date} · {block.entry.summary}
          </div>
          {block.entry.body.length > 0 && (
            <p className="mt-2 text-sm text-text-secondary leading-relaxed">
              {block.entry.body.join(' ')}
            </p>
          )}
        </div>
      );
    case 'table':
      return (
        <LogicTable
          headers={block.headers}
          rows={block.rows}
          dense={dense}
          highlightFirstColumn={highlightTableRow}
          interactive={interactive && !!sectionAnchorId}
          onRowClick={
            sectionAnchorId && onPrdPick
              ? (rowLabel) =>
                  onPrdPick({
                    anchorId: sectionAnchorId,
                    rowLabel,
                    sectionTitle,
                  })
              : undefined
          }
        />
      );
    default:
      return null;
  }
}

function listColumnsFor(sectionTitle: string): string[] {
  if (sectionTitle === '痛点') return ['序号', '痛点', '说明'];
  if (sectionTitle === '诉求与目标') return ['序号', '目标项'];
  return ['序号', '项目', '说明'];
}

export function LogicDocCard({
  id,
  title,
  icon,
  children,
  dense = false,
  highlighted = false,
  interactive = false,
  onHeaderClick,
  actions,
}: {
  id?: string;
  title: string;
  icon: string;
  children: ReactNode;
  dense?: boolean;
  highlighted?: boolean;
  interactive?: boolean;
  onHeaderClick?: () => void;
  /** 头部右侧操作区（如编辑按钮） */
  actions?: ReactNode;
}) {
  const headerCls = `bg-stone-50 border-b border-border-light ${dense ? 'px-3 py-2' : 'px-4 py-3'}`;
  const actionsNode = actions ? <div className="ml-auto flex items-center gap-1">{actions}</div> : null;
  return (
    <div
      id={id}
      className={`border rounded-lg overflow-hidden bg-white transition-shadow duration-300 ${
        dense ? 'mb-2' : 'mb-4'
      } ${highlighted ? 'border-primary ring-2 ring-primary/25 shadow-soft' : 'border-border'}`}
    >
      {interactive && onHeaderClick ? (
        <button
          type="button"
          className={`${headerCls} w-full text-left hover:bg-primary/5 transition-colors cursor-pointer`}
          onClick={onHeaderClick}
        >
          <h4 className={`font-semibold text-dark flex items-center ${dense ? 'text-xs' : 'text-sm'}`}>
            <FaIcon className={`${icon} text-primary mr-2`} />
            {title}
            <FaIcon className="fas fa-crosshairs ml-auto text-[10px] text-primary/40" aria-hidden />
          </h4>
        </button>
      ) : (
        <div className={`${headerCls} flex items-center`}>
          <h4 className={`font-semibold text-dark flex items-center ${dense ? 'text-xs' : 'text-sm'}`}>
            <FaIcon className={`${icon} text-primary mr-2`} />
            {title}
          </h4>
          {actionsNode}
        </div>
      )}
      <div className={dense ? 'p-2.5' : 'p-4'}>{children}</div>
    </div>
  );
}

function ListTable({ items, columns }: { items: ListItem[]; columns: string[] }) {
  const hasLabel = columns.length >= 3;

  return (
    <LogicTable
      headers={columns}
      rows={items.map((item, i) => {
        if (hasLabel) {
          return [
            String(i + 1),
            item.label ?? item.text,
            item.label ? item.text : '—',
          ];
        }
        return [String(i + 1), item.label ? `${item.label}：${item.text}` : item.text];
      })}
    />
  );
}

function ChecklistTable({ items, dense = false }: { items: CheckItem[]; dense?: boolean }) {
  return (
    <LogicTable
      dense={dense}
      headers={['序号', '验收项', '状态']}
      rows={items.map((item, i) => [
        String(i + 1),
        item.text,
        item.checked ? (
          <span key="ok" className="inline-flex items-center gap-1 text-success text-xs font-medium">
            <FaIcon className="fas fa-check" />
            已通过
          </span>
        ) : (
          <span key="pending" className="inline-flex items-center gap-1 text-text-muted text-xs">
            <FaIcon className="fas fa-minus" />
            待验收
          </span>
        ),
      ])}
    />
  );
}

function cellText(cell: string | ReactNode): string {
  if (typeof cell === 'string') return cell;
  return '';
}

export function LogicTable({
  headers,
  rows,
  dense = false,
  highlightFirstColumn = null,
  interactive = false,
  onRowClick,
}: {
  headers: string[];
  rows: (string | ReactNode)[][];
  dense?: boolean;
  highlightFirstColumn?: string | null;
  interactive?: boolean;
  onRowClick?: (rowLabel: string) => void;
}) {
  return (
    <div className="overflow-x-auto">
      <table className={`logic-table min-w-full border border-border rounded ${dense ? 'text-xs' : 'text-sm'}`}>
        <thead className="bg-stone-50">
          <tr>
            {headers.map((h) => (
              <th
                key={h}
                className={`text-left font-medium text-dark border-b border-border-light whitespace-nowrap ${
                  dense ? 'px-2 py-1.5' : 'px-3 py-2'
                }`}
              >
                {h}
              </th>
            ))}
          </tr>
        </thead>
        <tbody className="divide-y divide-border-light">
          {rows.map((row, ri) => {
            const labelCol = headers.findIndex((h) =>
              /按钮|检索项|列名|字段|逻辑项|触发条件|步骤|规则项|区块|展示内容/.test(h),
            );
            const matchCol = labelCol >= 0 ? labelCol : 0;
            const label = cellText(row[matchCol]);
            const rowHit =
              highlightFirstColumn &&
              (label.includes(highlightFirstColumn) || highlightFirstColumn.includes(label));
            const clickable = interactive && onRowClick && label;
            return (
              <tr
                key={ri}
                className={`${
                  rowHit ? 'bg-primary/10 ring-1 ring-inset ring-primary/30' : 'hover:bg-stone-50/80'
                } ${clickable ? 'cursor-pointer hover:bg-primary/5' : ''}`}
                onClick={clickable ? () => onRowClick(label) : undefined}
                role={clickable ? 'button' : undefined}
                tabIndex={clickable ? 0 : undefined}
                onKeyDown={
                  clickable
                    ? (e) => {
                        if (e.key === 'Enter' || e.key === ' ') {
                          e.preventDefault();
                          onRowClick(label);
                        }
                      }
                    : undefined
                }
              >
                {row.map((cell, ci) => (
                  <td
                    key={ci}
                    className={`${ci === 0 ? 'text-dark w-10' : 'text-text-secondary'} ${
                      dense ? 'px-2 py-1.5' : 'px-3 py-2'
                    } ${rowHit && ci === matchCol ? 'font-semibold text-primary' : ''}`}
                  >
                    {cell}
                  </td>
                ))}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  );
}

export { parseRequirementsDoc, type ParsedRequirementsDoc };

/**
 * PRD 章节编辑弹窗：以 Modal 形式编辑单个 section。
 * 当 sectionEditor.draft 不为 null 时显示。
 * 复用 EditableTable 与 EditableBlockRenderer 实现 inline 编辑。
 * 保存时使用传入的原始 section 的 startLine/endLine 拼接回 PRD 全文。
 */
export function PrdSectionEditModal({
  section,
  sectionEditor,
  project,
  originalPrdText,
  onClose,
}: {
  /** 原始 section（用于 startLine/endLine） */
  section: DocSection | null;
  sectionEditor: SectionEditorState;
  project: ProjectItem;
  originalPrdText: string;
  onClose: () => void;
}) {
  const draft = sectionEditor.draft;
  if (!draft) return null;

  return (
    <div
      className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
      role="dialog"
      aria-modal="true"
      aria-label="编辑 PRD 章节"
      onClick={(e) => {
        if (e.target === e.currentTarget && !sectionEditor.saving) onClose();
      }}
    >
      <div className="bg-white rounded-xl shadow-2xl w-full max-w-5xl max-h-[88vh] flex flex-col overflow-hidden">
        {/* Header */}
        <div className="px-5 py-3.5 border-b border-border-light flex items-center gap-2.5 bg-stone-50/60">
          <FaIcon className="fas fa-pen text-primary text-sm shrink-0" />
          <h3 className="font-semibold text-dark text-base truncate flex-1 min-w-0">
            {draft.title}
          </h3>
          {draft.anchorId && (
            <span className="text-[10px] font-mono text-text-muted bg-stone-100 px-1.5 py-0.5 rounded shrink-0">
              {draft.anchorId}
            </span>
          )}
          <button
            type="button"
            className="inline-flex items-center justify-center w-8 h-8 rounded-lg text-text-muted hover:text-dark hover:bg-stone-200 transition-colors shrink-0"
            title="关闭"
            aria-label="关闭"
            onClick={onClose}
            disabled={sectionEditor.saving}
          >
            <FaIcon className="fas fa-times" />
          </button>
        </div>

        {/* Body */}
        <div className="flex-1 overflow-y-auto p-5 space-y-5">
          {draft.blocks.length === 0 ? (
            <p className="text-text-muted text-sm text-center py-8">暂无内容</p>
          ) : (
            draft.blocks.map((block, i) => (
              <div key={`${draft.title}-${i}`} className="space-y-2">
                <div className="flex items-center gap-2">
                  <span className="text-[10px] font-medium text-text-muted uppercase tracking-wide">
                    {block.type === 'table' ? '表格' : block.type === 'paragraph' ? '段落' : block.type === 'list' ? '列表' : block.type === 'checklist' ? '检查项' : block.type === 'subsection' ? '子章节' : block.type}
                  </span>
                  <span className="flex-1 h-px bg-border-light" />
                </div>
                <EditableBlockRenderer
                  block={block}
                  blockIndex={i}
                  dense={false}
                  sectionEditor={sectionEditor}
                />
              </div>
            ))
          )}
        </div>

        {/* Footer */}
        <div className="px-5 py-3 border-t border-border-light flex items-center gap-2 bg-stone-50/60">
          <button
            type="button"
            className="btn btn-primary py-2 px-5 text-sm"
            disabled={sectionEditor.saving}
            onClick={() => {
              if (section) {
                void sectionEditor.save(project, originalPrdText, section);
              }
            }}
          >
            <FaIcon
              className={`fas ${sectionEditor.saving ? 'fa-spinner fa-spin' : 'fa-check'} mr-1.5`}
            />
            保存
          </button>
          <button
            type="button"
            className="btn btn-secondary py-2 px-5 text-sm"
            disabled={sectionEditor.saving}
            onClick={sectionEditor.cancelEdit}
          >
            取消
          </button>
          {sectionEditor.error ? (
            <span className="text-xs text-red-600 ml-2 flex items-center gap-1">
              <FaIcon className="fas fa-exclamation-circle" />
              {sectionEditor.error}
            </span>
          ) : null}
          {sectionEditor.message ? (
            <span className="text-xs text-emerald-700 ml-2 flex items-center gap-1">
              <FaIcon className="fas fa-check-circle" />
              {sectionEditor.message}
            </span>
          ) : null}
        </div>
      </div>
    </div>
  );
}

function EditableBlockRenderer({
  block,
  blockIndex,
  dense = false,
  sectionEditor,
}: {
  block: DocBlock;
  blockIndex: number;
  dense?: boolean;
  sectionEditor: SectionEditorState;
}) {
  switch (block.type) {
    case 'paragraph':
      return (
        <textarea
          className="w-full resize-y rounded-lg border border-border bg-white p-3 text-sm text-dark leading-relaxed outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-shadow"
          rows={Math.max(3, block.text.split('\n').length + 1)}
          value={block.text}
          onChange={(e) =>
            sectionEditor.updateDraft((draft) => {
              const target = draft.blocks[blockIndex];
              if (target && target.type === 'paragraph') {
                target.text = e.target.value;
              }
            })
          }
        />
      );
    case 'table':
      return (
        <EditableTable
          headers={block.headers}
          rows={block.rows}
          dense={dense}
          onHeadersChange={(headers) =>
            sectionEditor.updateDraft((draft) => {
              const target = draft.blocks[blockIndex];
              if (target && target.type === 'table') {
                target.headers = headers;
              }
            })
          }
          onChange={(rows) =>
            sectionEditor.updateDraft((draft) => {
              const target = draft.blocks[blockIndex];
              if (target && target.type === 'table') {
                target.rows = rows;
              }
            })
          }
        />
      );
    case 'list':
    case 'checklist':
    case 'subsection':
    case 'changelog-entry':
    default:
      // 编辑态下其他类型暂以只读形式渲染（保持兼容）
      return (
        <BlockRenderer
          block={block}
          sectionTitle=""
          dense={dense}
          highlightTableRow={null}
          interactive={false}
        />
      );
  }
}

/**
 * 可编辑表格组件：表头与每个单元格均为 <input>，支持添加/删除行。
 */
export function EditableTable({
  headers,
  rows,
  onChange,
  onHeadersChange,
  dense = false,
}: {
  headers: string[];
  rows: string[][];
  onChange: (rows: string[][]) => void;
  onHeadersChange?: (headers: string[]) => void;
  dense?: boolean;
}) {
  const colCount = headers.length;
  const inputCls = dense
    ? 'px-1.5 py-1 text-xs'
    : 'px-2.5 py-2 text-sm';

  const updateHeader = (ci: number, value: string) => {
    if (!onHeadersChange) return;
    const next = headers.map((h, i) => (i === ci ? value : h));
    onHeadersChange(next);
  };

  const updateCell = (ri: number, ci: number, value: string) => {
    const next = rows.map((row, i) => {
      if (i !== ri) return row;
      const newRow = [...row];
      newRow[ci] = value;
      return newRow;
    });
    onChange(next);
  };

  const addRow = () => {
    const newRow = Array.from({ length: colCount }, () => '');
    onChange([...rows, newRow]);
  };

  const removeRow = (ri: number) => {
    onChange(rows.filter((_, i) => i !== ri));
  };

  return (
    <div className="space-y-2">
      <div className="overflow-x-auto rounded-lg border border-border">
        <table className="min-w-full border-collapse">
          <thead className="bg-stone-50">
            <tr>
              {headers.map((h, ci) => (
                <th
                  key={ci}
                  className="text-left border-b border-border-light border-r border-r-border-light last:border-r-0 whitespace-nowrap"
                >
                  <input
                    type="text"
                    className={`w-full bg-transparent font-semibold text-dark outline-none focus:bg-primary/5 ${inputCls}`}
                    value={h}
                    onChange={(e) => updateHeader(ci, e.target.value)}
                    aria-label={`表头 ${ci + 1}`}
                  />
                </th>
              ))}
              <th className="border-b border-border-light w-10" aria-label="行操作" />
            </tr>
          </thead>
          <tbody className="divide-y divide-border-light">
            {rows.map((row, ri) => (
              <tr key={ri} className="hover:bg-stone-50/50 transition-colors">
                {headers.map((_, ci) => (
                  <td
                    key={ci}
                    className="border-r border-r-border-light last:border-r-0"
                  >
                    <input
                      type="text"
                      className={`w-full bg-transparent text-dark outline-none focus:bg-primary/8 ${inputCls}`}
                      value={row[ci] ?? ''}
                      onChange={(e) => updateCell(ri, ci, e.target.value)}
                      aria-label={`单元格 ${ri + 1}-${ci + 1}`}
                    />
                  </td>
                ))}
                <td className="text-center">
                  <button
                    type="button"
                    className="inline-flex items-center justify-center w-7 h-7 rounded text-text-muted hover:text-red-600 hover:bg-red-50 transition-colors"
                    title="删除该行"
                    aria-label="删除该行"
                    onClick={() => removeRow(ri)}
                  >
                    <FaIcon className="fas fa-trash text-[10px]" />
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <button
        type="button"
        className="inline-flex items-center gap-1.5 text-xs text-primary hover:text-primary-dark font-medium"
        onClick={addRow}
      >
        <FaIcon className="fas fa-plus text-[10px]" />
        添加行
      </button>
    </div>
  );
}
