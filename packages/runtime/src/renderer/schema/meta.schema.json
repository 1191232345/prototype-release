{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prototype-meta-schema",
  "title": "Prototype MetaInfo",
  "type": "object",
  "required": ["id", "version", "title", "project", "type", "mode", "designSystem", "author", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "发布预览 URL 标识，仅英文小写与连字符"
    },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["flow", "page"] },
    "pattern": { "type": "string" },
    "mode": { "type": "string", "enum": ["spec", "hybrid", "escape"] },
    "designSystem": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "changeSummary": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "review", "approved"] },
    "extensions": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "page" } } },
      "then": { "required": ["pattern"] }
    }
  ]
}
