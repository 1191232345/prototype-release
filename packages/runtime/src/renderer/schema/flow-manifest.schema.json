{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prototype-flow-manifest-schema",
  "title": "Prototype FlowManifest",
  "type": "object",
  "required": ["type", "title", "entry", "pages"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "flow" },
    "title": { "type": "string", "minLength": 1 },
    "entry": { "type": "string", "minLength": 1 },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "brand": { "type": "string" } }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    }
  }
}
