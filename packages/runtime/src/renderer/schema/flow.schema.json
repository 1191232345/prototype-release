{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prototype-flow-schema",
  "title": "Prototype FlowSpec",
  "type": "object",
  "required": ["type", "title", "entry", "pages"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "flow" },
    "title": { "type": "string", "minLength": 1 },
    "entry": { "type": "string", "minLength": 1 },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "brand": { "type": "string" } }
    },
    "pages": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "object" }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "title", "changes"],
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string" },
          "title": { "type": "string" },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["item", "desc"],
              "properties": {
                "item": { "type": "string" },
                "desc": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
