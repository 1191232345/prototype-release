{
  "pattern": "sku-fill-list",
  "title": "SKU 信息补充工单",
  "mainButtons": [
    {
      "id": "import",
      "label": "导入",
      "icon": "fas fa-file-import",
      "variant": "secondary",
      "action": "openImportModal"
    },
    {
      "id": "export",
      "label": "导出",
      "icon": "fas fa-file-export",
      "variant": "secondary",
      "action": "exportList"
    },
    {
      "id": "create",
      "label": "新建工单",
      "icon": "fas fa-plus",
      "variant": "primary",
      "action": "openModal",
      "modalId": "formModal"
    }
  ],
  "importModal": {
    "title": "批量导入工单",
    "asyncThreshold": 500,
    "filePresets": [
      { "fileName": "sku_workorder_import.xlsx", "totalRows": 3 },
      { "fileName": "sku_workorder_large.xlsx", "totalRows": 800 }
    ],
    "workOrderImportPreview": {
      "fileName": "sku_workorder_import.xlsx",
      "totalRows": 3,
