    {
      "id": "customer",
      "label": "客户代码",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "c1", "label": "客户A" },
        { "value": "c2", "label": "客户B" }
      ]
    },
    {
      "id": "status",
      "label": "工单状态",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "pending_warehouse", "label": "待仓库处理" },
        { "value": "pending_review", "label": "待客服审核" },
        { "value": "returned", "label": "已退回" },
        { "value": "completed", "label": "已完结" }
      ]
    },
    {
      "id": "warehouse",
      "label": "仓库代码",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "w1", "label": "洛杉矶仓" },
        { "value": "w2", "label": "纽约仓" },
        { "value": "w3", "label": "芝加哥仓" }
      ]
    },
    {
      "id": "priority",
      "label": "优先级",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "high", "label": "高" },
        { "value": "medium", "label": "中" },
        { "value": "low", "label": "低" }
      ]
    },
    {
      "id": "createdBy",
      "label": "创建人",
      "type": "text",
      "placeholder": "输入创建人"
    },
    {
      "id": "createTimeStart",
      "label": "创建时间（起）",
      "type": "datetime",
      "placeholder": "开始时间"
    },
    {
      "id": "createTimeEnd",
      "label": "创建时间（止）",
      "type": "datetime",
      "placeholder": "结束时间"
    }
