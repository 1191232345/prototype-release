{
  "pattern": "rule-config-list",
  "title": "快递补收列表",
  "mainButtons": [
    { "id": "import", "label": "导入", "icon": "fas fa-file-import", "variant": "primary", "action": "openImportModal" },
    { "id": "batchConfirm", "label": "批量确认", "icon": "fas fa-check-double", "variant": "secondary", "action": "batchConfirm" },
    { "id": "batchDelete", "label": "批量删除", "icon": "fas fa-trash", "variant": "danger", "action": "batchDelete" }
  ],
  "importModal": {
    "title": "导入承运商数据",
    "asyncThreshold": 1000,
    "filePresets": [
      { "fileName": "carrier_bill_20260705.xlsx", "totalRows": 25 },
      { "fileName": "carrier_bill_large.xlsx", "totalRows": 1500 }
    ],
    "customerPriceCardTable": {
      "fileName": "carrier_bill_20260705.xlsx",
      "totalRows": 25,
      "priceCardOptions": [
        { "value": "pc1", "label": "标准尾程价卡 v2.0" },
        { "value": "pc2", "label": "VIP 尾程价卡 v1.5" }
      ],
      "rows": [
        { "customerCode": "CUST-A", "customerName": "客户A", "rowCount": 15, "defaultPriceCard": "pc1" },
        { "customerCode": "CUST-B", "customerName": "客户B", "rowCount": 10, "defaultPriceCard": "pc2" }
      ]
    }
  },
  "filters": [
    { "id": "trackingNo", "label": "运单号", "type": "text", "placeholder": "输入运单号" },
    {
      "id": "customer",
      "label": "客户",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "c1", "label": "客户A" },
        { "value": "c2", "label": "客户B" }
      ]
    },
    {
      "id": "status",
      "label": "状态",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "draft", "label": "待确认" },
        { "value": "published", "label": "已确认" }
      ]
    },
    {
      "id": "matchStatus",
      "label": "匹配结果",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "success", "label": "匹配成功" },
        { "value": "failed", "label": "匹配失败" }
      ]
    },
    { "id": "importedBy", "label": "导入人", "type": "text", "placeholder": "输入导入人" },
    {
      "id": "deliveryChannel",
      "label": "配送渠道",
      "type": "select",
      "options": [
        { "value": "all", "label": "全部" },
        { "value": "ups", "label": "UPS" },
        { "value": "usps", "label": "USPS" },
        { "value": "fedex", "label": "FedEx" }
      ]
    },
    { "id": "importTimeStart", "label": "导入时间（起）", "type": "datetime" },
    { "id": "importTimeEnd", "label": "导入时间（止）", "type": "datetime" }
  ],
  "table": {
    "selectable": true,
    "columns": [
      { "key": "trackingNo", "label": "运单号" },
      { "key": "status", "label": "状态" },
