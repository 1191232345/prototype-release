{
  "pattern": "rule-config-form",
  "title": "新增基础价",
  "sections": [
    {
      "title": "基础信息",
      "icon": "fas fa-info-circle",
      "fields": [
        {
          "id": "name",
          "label": "名称",
          "type": "text",
          "required": true,
          "placeholder": "请输入名称"
        },
        {
          "id": "channel",
          "label": "渠道",
          "type": "select",
          "required": true,
          "options": [
            { "value": "ups-freight", "label": "UPS-Freight" },
            { "value": "fedex-ground", "label": "FedEx-Ground" },
            { "value": "dhl-express", "label": "DHL-Express" }
          ],
          "placeholder": "请选择渠道"
        },
        {
          "id": "carrier",
          "label": "承运商",
          "type": "select",
          "required": true,
          "options": [
            { "value": "ups", "label": "UPS" },
            { "value": "fedex", "label": "FedEx" },
            { "value": "dhl", "label": "DHL" }
          ],
          "placeholder": "请选择承运商"
        },
        {
          "id": "feeType",
          "label": "费用类型",
          "type": "select",
          "required": true,
          "options": [
            { "value": "base", "label": "基础价" },
            { "value": "surcharge", "label": "附加费" },
            { "value": "other", "label": "其他费用" }
          ]
        }
      ]
    },
    {
      "title": "分区报价配置",
      "icon": "fas fa-table",
      "visibleWhen": { "field": "feeType", "values": ["base"] },
      "zonePriceTable": {
        "zones": ["2区", "3区", "4区", "5区", "6区", "7区", "8区"],
        "weightSegments": [
          { "start": 0, "end": 0.5, "unit": "lb" },
          { "start": 0.5, "end": 1, "unit": "lb" },
          { "start": 1, "end": 2, "unit": "lb" },
          { "start": 2, "end": 5, "unit": "lb" }
        ],
        "prices": {
          "2区": [5.5, 6, 7, 9.5],
          "3区": [5.8, 6.3, 7.5, 10],
          "4区": [6.1, 6.6, 8, 10.5],
          "5区": [6.4, 7, 8.5, 11],
          "6区": [6.7, 7.4, 9, 11.5],
          "7区": [7, 7.8, 9.5, 12],
          "8区": [7.3, 8.2, 10, 12.5]
        },
        "currency": "USD",
        "priceUnit": "lb"
      }
    },
    {
      "title": "附加费管理",
      "icon": "fas fa-dollar-sign",
      "visibleWhen": { "field": "feeType", "values": ["surcharge"] },
      "surchargeTable": {
        "columns": [
          {
            "key": "feeItem",
            "label": "属性费用项",
            "type": "select",
            "options": [
              { "value": "fuel-surcharge", "label": "燃油附加费" },
              { "value": "remote-surcharge", "label": "偏远附加费" },
              { "value": "oversize-surcharge", "label": "超长附加费" },
              { "value": "residential-surcharge", "label": "住宅派送附加费" },
              { "value": "address-correction", "label": "地址修正费" },
              { "value": "other-surcharge", "label": "其他附加费" }
            ],
            "placeholder": "请选择费用项"
          },
          {
            "key": "unit",
            "label": "计费单位",
            "type": "select",
            "options": [
              { "value": "ticket", "label": "票" },
              { "value": "kg", "label": "kg" },
              { "value": "lb", "label": "lb" },
              { "value": "piece", "label": "件" }
            ],
            "placeholder": "请选择计费单位"
          },
          {
            "key": "price",
            "label": "单价",
            "type": "number"
          },
          {
            "key": "zones",
            "label": "分区",
            "type": "multiSelect",
            "options": [
              { "value": "2区", "label": "2区" },
              { "value": "3区", "label": "3区" },
              { "value": "4区", "label": "4区" },
              { "value": "5区", "label": "5区" },
              { "value": "6区", "label": "6区" },
              { "value": "7区", "label": "7区" },
              { "value": "8区", "label": "8区" }
            ]
          },
          {
            "key": "startWeight",
            "label": "起始重量",
            "type": "number"
          },
          {
            "key": "endWeight",
            "label": "结束重量",
            "type": "number"
          },
          {
            "key": "remark",
            "label": "备注",
            "type": "text",
            "placeholder": "请输入备注"
          }
        ],
        "rows": [
          {
            "feeItem": "fuel-surcharge",
            "unit": "ticket",
            "price": "5.00",
            "zones": "2区,3区,4区,5区,6区,7区,8区",
            "startWeight": "0",
            "endWeight": "999",
            "remark": "按票收取"
          },
          {
            "feeItem": "remote-surcharge",
            "unit": "ticket",
            "price": "25.00",
            "zones": "5区,6区,7区,8区",
            "startWeight": "0",
            "endWeight": "999",
            "remark": "偏远地区附加"
          },
          {
            "feeItem": "oversize-surcharge",
            "unit": "lb",
