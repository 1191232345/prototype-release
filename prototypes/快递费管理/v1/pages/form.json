            "placeholder": "请选择费用项"
          },
          {
            "key": "unit",
            "label": "计费单位",
            "type": "select",
            "options": [
              { "value": "ticket", "label": "票" },
              { "value": "kg", "label": "kg" },
              { "value": "lb", "label": "lb" },
              { "value": "piece", "label": "件" }
            ],
