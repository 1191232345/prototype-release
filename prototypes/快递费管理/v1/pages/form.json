            "zones": "2区,3区,4区",
            "startWeight": "70",
            "endWeight": "150",
            "remark": "超长包裹"
          }
        ]
      }
    },
    {
      "title": "其他费用管理",
      "icon": "fas fa-file-invoice-dollar",
      "visibleWhen": { "field": "feeType", "values": ["other"] },
      "surchargeTable": {
        "columns": [
          {
            "key": "feeItem",
